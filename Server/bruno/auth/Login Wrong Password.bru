meta {
  name: Login - Wrong Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "player@greenskills.com",
    "password": "wrongpassword"
  }
}

assert {
  res.status: eq 401
  res.body.error: eq invalid email or password
}
