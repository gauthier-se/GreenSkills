meta {
  name: Register - Duplicate Email
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "player@greenskills.com",
    "username": "differentuser",
    "password": "password123"
  }
}

assert {
  res.status: eq 409
  res.body.error: eq email already registered
}
